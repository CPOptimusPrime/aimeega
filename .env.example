# ─── Supabase ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Clerk Auth ──────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxx
CLERK_SECRET_KEY=sk_live_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/discover
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── Cloudflare Stream ───────────────────────
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_STREAM_API_TOKEN=your-api-token
NEXT_PUBLIC_CLOUDFLARE_CUSTOMER_SUBDOMAIN=customer-xxxx.cloudflarestream.com

# ─── Hive Moderation ─────────────────────────
HIVE_API_KEY=your-hive-key

# ─── App ─────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://aimeega.com
NEXT_PUBLIC_APP_NAME=Aimeega
